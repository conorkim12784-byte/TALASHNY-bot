# ================================================
#       World Music Bot - ملف الإعدادات
# ================================================

# رمز البوت من @BotFather
BOT_TOKEN=

# اسم مستخدم البوت بدون @
BOT_USERNAME=WorldMusicly_Bot

# اسم البوت
BOT_NAME=World Music

# API ID من my.telegram.org
API_ID=

# API Hash من my.telegram.org
API_HASH=

# Session String للحساب المساعد (يولد بـ Pyrogram)
SESSION_NAME=

# رابط MongoDB من cloud.mongodb.com
MONGODB_URL=

# ================================================
#       إعدادات الملاك والمشرفين
# ================================================

# ID المالك الرئيسي للبوت
SUDO_USERS=

# اسم مستخدم المالك بدون @
OWNER_NAME=WORLD_MUSIC_F

# اسم الحساب المساعد بدون @
ASSISTANT_NAME=World_Musicly

# ================================================
#       إعدادات اختيارية
# ================================================

# اسم ظهور البوت
ALIVE_NAME=World Music Bot

# الحد الأقصى لمدة الأغنية بالدقائق
DURATION_LIMIT=240

# اسم قناة التحديثات بدون @
UPDATES_CHANNEL=Ch_World_Music

# اسم جروب الدعم بدون @
GROUP_SUPPORT=Gr_World_Music

# رابط صورة البوت
BOT_PHOTO=https://telegra.ph/file/a6c96cdbd066ca2388d06.jpg

# رابط صورة المطور
DEV_PHOTO=https://telegra.ph/file/a6c96cdbd066ca2388d06.jpg

# اسم المطور
DEV_NAME=Developer
